# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is git-ignored.

# Database (Neon PostgreSQL)
# Get from https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: separate URL for production branch (used by ops scripts in /scripts/db)
# DATABASE_URL_PROD="postgresql://user:password@host/dbname?sslmode=require"

# Site URL — must match your live domain, no trailing slash
NEXT_PUBLIC_SITE_URL="https://example.com"

# Search engine verification codes (leave empty until you have them)
GOOGLE_SITE_VERIFICATION=""
BING_SITE_VERIFICATION=""
YANDEX_SITE_VERIFICATION=""

# Email service (Resend) — required if you wire up the contact form
RESEND_API_KEY=""
FROM_EMAIL="noreply@example.com"
TO_EMAIL="owner@example.com"

# Analytics (optional)
GOOGLE_ANALYTICS_ID=""

# Admin panel
# Set a strong password — this protects /admin. Never commit the real value.
ADMIN_PASSWORD=""
# Optional: separate signing key for the session cookie. If empty, the
# password is used as the signing key. Set a long random string in production.
ADMIN_SESSION_SECRET=""

